# ============================================
# MediVoice Server Configuration
# Copy to .env and fill in values
# ============================================

# Application
APP_NAME=MediVoice
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development
API_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=1
RELOAD=true

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","*"]

# Database - SQLite for local dev (FREE)
DATABASE_URL=sqlite+aiosqlite:///./medivoice.db

# For production with Neon.tech (FREE TIER)
# DATABASE_URL=postgresql://user:pass@ep-xxxx.us-east-2.aws.neon.tech/medivoice

# Redis (optional for local dev, free tier for production)
# Leave empty to use in-memory storage
REDIS_URL=
# REDIS_URL=redis://localhost:6379/0

# JWT Authentication
JWT_SECRET_KEY=change-this-to-a-random-secret-key-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Session Configuration
SESSION_TIMEOUT_MINUTES=10
MAX_NOTES_PER_SESSION=5

# ============================================
# AI/ML Configuration (FREE OPTIONS)
# ============================================

# Option 1: Groq Cloud (FREE TIER - Recommended for MVP)
# Sign up at https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=whisper-large-v3
GROQ_LLM_MODEL=llama-3.1-70b-versatile

# Option 2: Ollama (FREE - Local)
# Install from https://ollama.ai
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_STT_MODEL=whisper
OLLAMA_LLM_MODEL=llama3.1:8b

# Option 3: OpenAI (PAID - Optional)
OPENAI_API_KEY=sk-your-key-here
# Use for STT
OPENAI_WHISPER_MODEL=whisper-1
# Use for formatting
OPENAI_LLM_MODEL=gpt-3.5-turbo

# ============================================
# Feature Flags (MVP)
# ============================================
ENABLE_MULTI_TEMPLATE=false
ENABLE_OFFLINE_MODE=false
ENABLE_BACKGROUND_RECORDING=false
ENABLE_AUDIT_LOGGING=false

# ============================================
# Security
# ============================================
ENCRYPTION_ENABLED=false
RATE_LIMIT_ENABLED=false
RATE_LIMIT_PER_MINUTE=30

# ============================================
# Logging
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json
