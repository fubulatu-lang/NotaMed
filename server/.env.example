# ============================================
# MediVoice Server Configuration - CLOUD ONLY
# No local AI - all processing via cloud APIs
# ============================================

# Application
APP_NAME=MediVoice
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development
API_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=1
RELOAD=true

# CORS - Allow phone and web access
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","https://medivoice.vercel.app","*"]

# Database - Neon.tech (Cloud PostgreSQL) or SQLite for testing
# For production, use Neon.tech free tier: https://neon.tech
DATABASE_URL=sqlite+aiosqlite:///./medivoice.db
# DATABASE_URL=postgresql://user:pass@ep-xxxx.us-east-2.aws.neon.tech/medivoice

# Redis - Upstash (Cloud Redis) Optional for MVP
# Free tier: https://upstash.com
REDIS_URL=

# JWT Authentication
JWT_SECRET_KEY=change-this-to-a-random-secret-key-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Session Configuration
SESSION_TIMEOUT_MINUTES=10
MAX_NOTES_PER_SESSION=5

# ============================================
# AI/ML - CLOUD APIs ONLY
# ============================================

# AI Provider: "groq" (FREE) or "openai" (PAID)
AI_PROVIDER=groq

# Option 1: Groq Cloud (FREE - Recommended)
# Get free API key at https://console.groq.com
# Provides: Whisper for STT + Llama 3.1 for formatting
GROQ_API_KEY=gsk_your_free_groq_api_key_here
GROQ_STT_MODEL=whisper-large-v3
GROQ_LLM_MODEL=llama-3.1-70b-versatile

# Option 2: OpenAI (PAID - Backup option)
# Get API key at https://platform.openai.com
OPENAI_API_KEY=
OPENAI_STT_MODEL=whisper-1
OPENAI_LLM_MODEL=gpt-3.5-turbo

# ============================================
# Feature Flags (MVP)
# ============================================
ENABLE_MULTI_TEMPLATE=false
ENABLE_OFFLINE_MODE=false
ENABLE_BACKGROUND_RECORDING=false
ENABLE_AUDIT_LOGGING=false

# ============================================
# Security
# ============================================
ENCRYPTION_ENABLED=false
RATE_LIMIT_ENABLED=false
RATE_LIMIT_PER_MINUTE=30

# ============================================
# Logging
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json
