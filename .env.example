# ============================================
# MediVoice Environment Variables
# Copy this file to .env and fill in values
# ============================================

# App Configuration
APP_NAME=MediVoice
APP_ENV=development
APP_VERSION=0.1.0
DEBUG=true

# Backend API URL
API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# Database (Neon.tech)
DATABASE_URL=postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/medivoice?sslmode=require
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis (for session management)
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Session Configuration
SESSION_TIMEOUT_MINUTES=10
MAX_SESSION_NOTES=5

# STT Engine (choose one)
# Option 1: AWS Transcribe Medical
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_TRANSCRIBE_MEDICAL_BUCKET=medivoice-transcriptions

# Option 2: Google Cloud Medical STT
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
GOOGLE_PROJECT_ID=your-project-id

# Option 3: OpenAI Whisper
OPENAI_API_KEY=sk-your-openai-api-key
WHISPER_MODEL=whisper-1

# LLM Engine
# Option 1: Azure OpenAI (HIPAA Compliant)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-api-key
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Option 2: AWS Bedrock
AWS_BEDROCK_MODEL_ID=anthropic.claude-v2
AWS_BEDROCK_REGION=us-east-1

# Encryption
ENCRYPTION_KEY=your-32-byte-encryption-key-change-me
SALT=your-encryption-salt

# Rate Limiting
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_HOUR=500

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
AUDIT_LOG_ENABLED=true

# Feature Flags
ENABLE_OFFLINE_MODE=false
ENABLE_BACKGROUND_RECORDING=false
ENABLE_MULTI_TEMPLATE=false
ENABLE_FHIR_EXPORT=false
