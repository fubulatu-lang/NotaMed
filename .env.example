# ============================================
# MediVoice Environment Variables - CLOUD ONLY
# Copy this file to .env and fill in values
# All AI processing via cloud APIs
# ============================================

# App Configuration
APP_NAME=MediVoice
APP_ENV=development
APP_VERSION=0.1.0
DEBUG=true

# URLs
API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# Database - Neon.tech (Cloud PostgreSQL)
# Sign up for free at https://neon.tech
DATABASE_URL=postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/medivoice?sslmode=require
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis - Upstash (Cloud Redis) Optional
REDIS_URL=
REDIS_PASSWORD=

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Session Configuration
SESSION_TIMEOUT_MINUTES=10
MAX_SESSION_NOTES=5

# ============================================
# AI APIs - CLOUD PROCESSING ONLY
# ============================================

# Primary: Groq Cloud (FREE TIER)
# Get free API key: https://console.groq.com
GROQ_API_KEY=gsk_your_free_groq_api_key_here

# Backup: OpenAI (PAID)
OPENAI_API_KEY=

# Active provider: "groq" or "openai"
AI_PROVIDER=groq

# Encryption
ENCRYPTION_KEY=your-32-byte-encryption-key-change-me
SALT=your-encryption-salt

# Rate Limiting
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_HOUR=500

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
AUDIT_LOG_ENABLED=true

# Feature Flags (MVP)
ENABLE_OFFLINE_MODE=false
ENABLE_BACKGROUND_RECORDING=false
ENABLE_MULTI_TEMPLATE=false
ENABLE_FHIR_EXPORT=false
